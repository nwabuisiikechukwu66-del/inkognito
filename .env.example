# ============================================================
# INKOGNITO — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Convex ───────────────────────────────────────────────────
# Get this after running: npx convex dev
# Found in your Convex dashboard → Settings → URL & Deploy Key
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ── Groq AI ──────────────────────────────────────────────────
# Free tier at: https://console.groq.com
# Powers the AI companion (Llama 3.1-8B-Instant)
# Set this in Convex dashboard → Settings → Environment Variables
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── AWS Rekognition (Image Moderation) ───────────────────────
# Free tier: 5,000 images/month
# https://aws.amazon.com/rekognition/
# Also set these in Convex dashboard environment variables
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ── Cloudflare R2 (Media Storage) ────────────────────────────
# Free: 10GB storage, 1M Class A ops/month
# https://dash.cloudflare.com → R2
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_BUCKET=inkognito-media
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Google AdSense ────────────────────────────────────────────
# Apply at: https://adsense.google.com
# Replace ad slot placeholders in FeedPage.tsx and FeedSidebar
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
